{%- comment -%}
  Renders an inline SVG icon. Usage: {% render 'icon', name: 'cart', size: 22 %}
  Single stroke style keeps the UI calm and consistent.
{%- endcomment -%}
{%- liquid
  assign s = size | default: 22
  assign sw = stroke | default: 1.7
-%}
<svg class="icon icon--{{ name }}" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ sw }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
{%- case name -%}
  {%- when 'search' -%}<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>
  {%- when 'cart' -%}<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/>
  {%- when 'user' -%}<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
  {%- when 'menu' -%}<path d="M3 6h18M3 12h18M3 18h18"/>
  {%- when 'close' -%}<path d="M18 6 6 18M6 6l12 12"/>
  {%- when 'chevron-down' -%}<path d="m6 9 6 6 6-6"/>
  {%- when 'chevron-right' -%}<path d="m9 6 6 6-6 6"/>
  {%- when 'chevron-left' -%}<path d="m15 6-6 6 6 6"/>
  {%- when 'arrow-right' -%}<path d="M5 12h14M13 6l6 6-6 6"/>
  {%- when 'plus' -%}<path d="M12 5v14M5 12h14"/>
  {%- when 'minus' -%}<path d="M5 12h14"/>
  {%- when 'shield' -%}<path d="M12 3 4 6v6c0 5 3.4 7.7 8 9 4.6-1.3 8-4 8-9V6z"/><path d="m9 12 2 2 4-4"/>
  {%- when 'truck' -%}<path d="M1 4h13v12H1zM14 8h4l3 3v5h-7"/><circle cx="6" cy="18" r="1.6"/><circle cx="18" cy="18" r="1.6"/>
  {%- when 'headset' -%}<path d="M4 14v-2a8 8 0 0 1 16 0v2"/><path d="M4 14a2 2 0 0 1 2-2h1v5H6a2 2 0 0 1-2-2zM20 14a2 2 0 0 0-2-2h-1v5h1a2 2 0 0 0 2-2z"/><path d="M20 16v1a4 4 0 0 1-4 4h-2"/>
  {%- when 'rotate' -%}<path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/>
  {%- when 'lock' -%}<rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>
  {%- when 'check' -%}<path d="M20 6 9 17l-5-5"/>
  {%- when 'star' -%}<path d="M12 3l2.7 5.5 6 .9-4.3 4.2 1 6-5.4-2.8L6.6 19.6l1-6L3.3 9.4l6-.9z"/>
  {%- when 'tag' -%}<path d="M20 12 12 20l-8-8V4h8z"/><circle cx="8" cy="8" r="1.4"/>
  {%- when 'sun' -%}<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"/>
  {%- when 'moon' -%}<path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
  {%- when 'phone' -%}<rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/>
  {%- when 'laptop' -%}<rect x="3" y="5" width="18" height="11" rx="1"/><path d="M2 20h20"/>
  {%- when 'home' -%}<path d="M3 11 12 3l9 8"/><path d="M5 10v10h14V10"/>
  {%- when 'watch' -%}<circle cx="12" cy="12" r="5"/><path d="M9 3h6l-1 4H10zM9 21h6l-1-4H10z"/><path d="M12 10v2.5l1.5 1"/>
  {%- when 'monitor' -%}<rect x="2" y="4" width="20" height="13" rx="1"/><path d="M8 21h8M12 17v4"/>
  {%- when 'instagram' -%}<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/>
  {%- when 'facebook' -%}<path d="M15 3h-2a4 4 0 0 0-4 4v3H6v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h2z"/>
  {%- when 'x' -%}<path d="M4 4l16 16M20 4 4 20"/>
  {%- when 'youtube' -%}<rect x="2" y="6" width="20" height="12" rx="3"/><path d="m10 9 5 3-5 3z"/>
  {%- when 'tiktok' -%}<path d="M15 4v8.5a4 4 0 1 1-3-3.9"/><path d="M15 4a4 4 0 0 0 4 4"/>
  {%- when 'package' -%}<path d="M12 2 3 7v10l9 5 9-5V7z"/><path d="M3 7l9 5 9-5M12 12v10"/>
  {%- when 'mail' -%}<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
{%- endcase -%}
</svg>
