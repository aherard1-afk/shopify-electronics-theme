{%- comment -%} Password / coming-soon page. Uses layout/password.liquid. {%- endcomment -%}
<div class="card" style="max-width:440px;width:100%;padding:36px;text-align:center">
  <a href="{{ routes.root_url }}" class="header__logo" style="justify-content:center;font-size:1.4rem;margin-bottom:8px"><span class="logo-mark">●</span>{{ settings.logo_text | default: shop.name }}</a>
  <p class="text-muted" style="margin-bottom:22px">{{ shop.password_message | default: "We're getting things ready. Enter the store password to take a look." }}</p>
  {%- form 'storefront_password' -%}
    {%- if form.errors -%}<p style="color:var(--danger);margin-bottom:10px">Incorrect password — please try again.</p>{%- endif -%}
    <div class="input-group">
      <input class="input" type="password" name="password" placeholder="Store password" aria-label="Store password" required>
      <button type="submit" class="btn btn--accent">Enter</button>
    </div>
  {%- endform -%}
  <p class="text-faint" style="font-size:.8rem;margin-top:18px">Are you the store owner? <a href="/admin" style="color:var(--accent)">Log in here</a>.</p>
</div>
