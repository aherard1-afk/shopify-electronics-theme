<section class="section"><div class="page-width" style="max-width:440px">
  <h1 style="text-align:center;margin-bottom:24px">Create account</h1>
  <div class="card" style="padding:28px">
    {%- form 'create_customer' -%}
      {%- if form.errors -%}<p style="color:var(--danger);margin-bottom:12px">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div class="grid" style="grid-template-columns:1fr 1fr;gap:12px">
        <div class="field"><label for="rf">First name</label><input class="input" id="rf" name="customer[first_name]"></div>
        <div class="field"><label for="rl">Last name</label><input class="input" id="rl" name="customer[last_name]"></div>
      </div>
      <div class="field" style="margin-top:14px"><label for="re">Email</label><input class="input" id="re" type="email" name="customer[email]" required></div>
      <div class="field" style="margin-top:14px"><label for="rp">Password</label><input class="input" id="rp" type="password" name="customer[password]" required></div>
      <button type="submit" class="btn btn--accent btn--block" style="margin-top:16px">Create account</button>
    {%- endform -%}
    <p style="text-align:center;margin-top:18px;font-size:.9rem">Already have an account? <a href="{{ routes.account_login_url }}" style="color:var(--accent)">Sign in</a></p>
  </div>
</div></section>
