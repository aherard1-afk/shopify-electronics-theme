<section class="section"><div class="page-width" style="max-width:820px">
  <a href="{{ routes.account_url }}" class="link-arrow" style="margin-bottom:14px;display:inline-flex">{% render 'icon', name: 'chevron-left', size: 14 %} Back to account</a>
  <h1 style="margin-bottom:6px">Order {{ order.name }}</h1>
  <p class="text-muted" style="margin-bottom:22px">Placed {{ order.created_at | date: '%B %d, %Y' }} · {{ order.financial_status }}{% if order.fulfillment_status %} · {{ order.fulfillment_status }}{% endif %}</p>
  <div class="card">
    {%- for line in order.line_items -%}
      <div class="cart-line" style="grid-template-columns:60px 1fr auto;padding:14px 16px">
        {%- if line.image -%}<img class="cart-line__media" src="{{ line.image | image_url: width: 120 }}" alt="{{ line.title | escape }}" width="60" height="60">{%- else -%}<div></div>{%- endif -%}
        <div><div class="cart-line__title">{{ line.title }}</div><div class="text-muted" style="font-size:.85rem">Qty {{ line.quantity }}</div></div>
        <div style="font-weight:650">{{ line.final_line_price | money }}</div>
      </div>
    {%- endfor -%}
    <div style="padding:16px;display:grid;gap:6px">
      <div style="display:flex;justify-content:space-between"><span class="text-muted">Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
      <div style="display:flex;justify-content:space-between"><span class="text-muted">Shipping</span><span>{{ order.shipping_price | money }}</span></div>
      <div style="display:flex;justify-content:space-between"><span class="text-muted">Tax</span><span>{{ order.tax_price | money }}</span></div>
      <div style="display:flex;justify-content:space-between;font-weight:700;font-size:1.05rem;border-top:1px solid var(--border);padding-top:8px;margin-top:4px"><span>Total</span><span>{{ order.total_net_amount | money }}</span></div>
    </div>
  </div>
</div></section>
