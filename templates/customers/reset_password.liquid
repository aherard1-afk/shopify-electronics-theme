<section class="section"><div class="page-width" style="max-width:420px">
  <h1 style="text-align:center;margin-bottom:22px">Reset password</h1>
  <div class="card" style="padding:28px">
    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}<p style="color:var(--danger);margin-bottom:12px">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div class="field" style="margin-bottom:14px"><label for="np">New password</label><input class="input" id="np" type="password" name="customer[password]" required></div>
      <div class="field"><label for="npc">Confirm password</label><input class="input" id="npc" type="password" name="customer[password_confirmation]" required></div>
      <button type="submit" class="btn btn--accent btn--block" style="margin-top:16px">Reset password</button>
    {%- endform -%}
  </div>
</div></section>
