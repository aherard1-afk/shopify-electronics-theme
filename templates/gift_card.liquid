{%- comment -%} Gift card template. {%- endcomment -%}
<section class="section">
  <div class="page-width" style="max-width:480px;text-align:center">
    <span class="eyebrow">{{ shop.name }}</span>
    <h1 style="margin:8px 0 6px">Gift card</h1>
    <p class="text-muted" style="margin-bottom:20px">Present this code at checkout.</p>
    <div class="card" style="padding:28px">
      <div style="font-size:clamp(2rem,6vw,3rem);font-weight:700;color:var(--accent)">{{ gift_card.balance | money }}</div>
      {%- if gift_card.expired -%}<p style="color:var(--danger);margin-top:8px">This gift card has expired.</p>{%- endif -%}
      <div class="input-group" style="margin-top:12px">
        <input class="input" type="text" value="{{ gift_card.code | format_code }}" readonly aria-label="Gift card code" style="text-align:center;letter-spacing:.1em">
      </div>
      <a href="{{ shop.url }}" class="btn btn--accent btn--block" style="margin-top:16px">Shop now</a>
    </div>
  </div>
</section>
