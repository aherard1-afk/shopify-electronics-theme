[
  {
    "name": "theme_info",
    "theme_name": "Northwire Electronics",
    "theme_version": "1.0.0",
    "theme_author": "Custom build",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://help.shopify.com/"
  },
  {
    "name": "Brand",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image (optional)" },
      { "type": "text", "id": "logo_text", "label": "Logo text", "default": "NORTHWIRE" },
      { "type": "image_picker", "id": "favicon", "label": "Favicon" },
      { "type": "textarea", "id": "brand_mission", "label": "Brand mission (footer)", "default": "Trusted electronics for work, home, and everything in between — curated, supported, and shipped with care." }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "header", "content": "Accent" },
      { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#3a6ea5", "info": "One refined tech accent. Used for CTAs, links, active states." },
      { "type": "color", "id": "accent_color_hover", "label": "Accent hover", "default": "#2f5a87" },
      { "type": "header", "content": "Dark mode" },
      { "type": "checkbox", "id": "respect_os_theme", "label": "Match visitor's OS theme on first visit", "default": false, "info": "Light mode stays the default unless this is on." }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
      { "type": "font_picker", "id": "body_font", "label": "Body font", "default": "assistant_n4" }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
      { "type": "checkbox", "id": "show_rating", "label": "Show review rating", "default": true, "info": "Reads metafields from Judge.me / Loox / Shopify Product Reviews if present." },
      { "type": "checkbox", "id": "show_secondary_image", "label": "Hover image swap", "default": true },
      { "type": "checkbox", "id": "show_quick_view", "label": "Show quick view button", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "select", "id": "cart_type", "label": "Cart type", "options": [ { "value": "drawer", "label": "Drawer" }, { "value": "page", "label": "Page" } ], "default": "drawer" },
      { "type": "richtext", "id": "cart_reassurance", "label": "Checkout reassurance", "default": "<p>Secure checkout. Encrypted payment. Easy returns.</p>" }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_x", "label": "X / Twitter URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" }
    ]
  },
  {
    "name": "Support",
    "settings": [
      { "type": "text", "id": "support_email", "label": "Support email", "default": "support@example.com" },
      { "type": "text", "id": "support_phone", "label": "Support phone", "default": "" },
      { "type": "text", "id": "support_hours", "label": "Support hours", "default": "Mon–Fri, 9am–6pm" }
    ]
  }
]
