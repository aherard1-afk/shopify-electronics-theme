<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }}</title>
    {%- if settings.favicon != blank -%}<link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}">{%- endif -%}
    {{ content_for_header }}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}
    <style>:root{--accent:{{ settings.accent_color | default: '#3a6ea5' }};}</style>
  </head>
  <body class="template-password">
    <main style="min-height:100vh;display:grid;place-items:center;padding:40px 20px">
      {{ content_for_layout }}
    </main>
    <script src="{{ 'global.js' | asset_url }}" defer></script>
  </body>
</html>
