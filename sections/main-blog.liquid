{%- comment -%} Blog / buying guides listing. {%- endcomment -%}
<div class="collection-banner"><div class="page-width collection-banner__inner"><span class="eyebrow">Guides &amp; news</span><h1>{{ blog.title }}</h1></div></div>
<section class="section">
  <div class="page-width">
    {%- if blog.articles.size > 0 -%}
      <div class="product-grid" style="grid-template-columns:repeat(3,1fr)">
        {%- for article in blog.articles -%}
          <a class="card reveal" href="{{ article.url }}">
            {%- if article.image -%}<div style="aspect-ratio:16/10;overflow:hidden">{{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title, class: 'cat-tile__img', style: 'width:100%;height:100%;object-fit:cover' }}</div>{%- endif -%}
            <div style="padding:18px">
              <span class="product-card__vendor">{{ article.published_at | date: '%b %d, %Y' }}</span>
              <h3 style="font-size:var(--fs-h4);margin:6px 0 8px">{{ article.title }}</h3>
              <p class="text-muted" style="font-size:.9rem">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
              <span class="link-arrow" style="margin-top:12px">Read guide {% render 'icon', name: 'arrow-right', size: 15 %}</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="empty-state">{% render 'icon', name: 'package', size: 40 %}<h2 style="margin:14px 0 8px">No posts yet</h2><p class="text-muted">Buying guides and tech tips will appear here.</p></div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
