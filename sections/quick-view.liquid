{%- comment -%} Quick view content — fetched via /products/{handle}?section_id=quick-view. {%- endcomment -%}
{%- assign current = product.selected_or_first_available_variant -%}
<div data-quick-view-inner>
  <div class="product" style="padding:28px;gap:28px;grid-template-columns:1fr 1fr">
    <div>
      {%- if product.featured_media -%}<img class="product__main-img" src="{{ product.featured_media | image_url: width: 800 }}" alt="{{ product.featured_media.alt | default: product.title | escape }}" width="500" height="500">{%- endif -%}
    </div>
    <div class="product__info">
      {%- if product.vendor != blank -%}<span class="product-card__vendor">{{ product.vendor }}</span>{%- endif -%}
      <h2 style="font-size:var(--fs-h3)">{{ product.title }}</h2>
      {% render 'rating', product: product %}
      <div class="product__price-row" style="font-size:var(--fs-h4)">{% render 'price', variant: current %}</div>
      {%- if product.description != blank -%}<p class="text-muted" style="font-size:.9rem">{{ product.description | strip_html | truncatewords: 36 }}</p>{%- endif -%}

      <form method="post" action="/cart/add" data-add-to-cart data-product-form>
        <script type="application/json" data-variant-json>[{%- for v in product.variants -%}{"id":{{ v.id }},"price":{{ v.price }},"available":{{ v.available }},"options":{{ v.options | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]</script>
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="variant-group" data-option-index="{{ forloop.index0 }}">
              <span class="field-label">{{ option.name }}</span>
              <div class="variant-options">
                {%- for value in option.values -%}
                  <label class="variant-opt {% if option.selected_value == value %}is-selected{% endif %}"><input type="radio" name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}> {{ value }}</label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}
        <input type="hidden" name="id" value="{{ current.id }}" data-variant-id>
        <button type="submit" class="btn btn--accent btn--lg btn--block" data-atc-btn style="margin-top:14px" {% unless current.available %}disabled{% endunless %}><span data-btn-label>{% if current.available %}{{ 'products.product.add_to_cart' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}</span></button>
      </form>
      <a href="{{ product.url }}" class="btn btn--ghost btn--block" style="margin-top:8px">{{ 'products.product.view_details' | t }} {% render 'icon', name: 'arrow-right', size: 14 %}</a>
    </div>
  </div>
</div>
{% schema %}
{ "name": "Quick view", "settings": [] }
{% endschema %}
