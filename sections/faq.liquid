{%- comment -%} FAQ accordion. Used on homepage (preview) and the full FAQ page. {%- endcomment -%}
<section class="section">
  <div class="page-width" style="max-width:840px">
    <div class="section-head" style="justify-content:center;text-align:center"><div class="section-head__titles" style="margin-inline:auto">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading | default: 'Frequently asked questions' }}</h2>
    </div></div>

    <div class="accordion">
      {%- for block in section.blocks -%}
        <div class="accordion__item" {{ block.shopify_attributes }}>
          <h3>
            <button type="button" class="accordion__btn" data-accordion-btn aria-expanded="false" aria-controls="faq-{{ section.id }}-{{ forloop.index }}">
              {{ block.settings.question }} {% render 'icon', name: 'chevron-down', size: 18 %}
            </button>
          </h3>
          <div class="accordion__panel" id="faq-{{ section.id }}-{{ forloop.index }}" data-open="false"><div><p>{{ block.settings.answer }}</p></div></div>
        </div>
      {%- else -%}
        {%- assign qs = 'How long does shipping take?|Shipping times depend on your location and the product. Estimated times appear at checkout. (Store owner: confirm processing + delivery windows.)|Do products include warranty?|Most products include a manufacturer or store warranty. See the Warranty page for details.|Can I return an item?|Yes — see our Returns & Refunds page for the return window and steps.|How do I track my order?|You will receive tracking by email once your order ships. You can also track from your account.|Do you sell digital and physical products?|Yes — we carry both physical electronics and digital products.|How can I contact support?|Reach our team via the Contact page or by email; hours are listed there.' | split: '|' -%}
        {%- for i in (0..5) -%}
          {%- assign qi = i | times: 2 -%}{%- assign ai = qi | plus: 1 -%}
          <div class="accordion__item">
            <h3><button type="button" class="accordion__btn" data-accordion-btn aria-expanded="false" aria-controls="faq-d-{{ i }}">{{ qs[qi] }} {% render 'icon', name: 'chevron-down', size: 18 %}</button></h3>
            <div class="accordion__panel" id="faq-d-{{ i }}" data-open="false"><div><p>{{ qs[ai] }}</p></div></div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_link -%}
      <div style="text-align:center;margin-top:24px"><a href="{{ section.settings.link | default: '/pages/faqs' }}" class="btn btn--outline">See all FAQs</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Answers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "checkbox", "id": "show_link", "label": "Show 'See all FAQs' button", "default": true },
    { "type": "url", "id": "link", "label": "FAQ page link" }
  ],
  "blocks": [
    { "type": "qa", "name": "Question", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
      { "type": "textarea", "id": "answer", "label": "Answer", "default": "Shipping times depend on your location and product." }
    ] }
  ],
  "presets": [ { "name": "FAQ" } ]
}
{% endschema %}
