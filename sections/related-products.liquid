{%- comment -%} "You may also like" — Shopify product recommendations. {%- endcomment -%}
{%- if recommendations.performed and recommendations.products_count > 0 -%}
  <section class="section">
    <div class="page-width">
      <div class="section-head"><div class="section-head__titles"><h2>{{ section.settings.heading | default: 'You may also like' }}</h2></div></div>
      <div class="carousel" data-carousel>
        <button class="carousel__nav carousel__nav--prev" data-carousel-prev aria-label="Previous">{% render 'icon', name: 'chevron-left', size: 18 %}</button>
        <div class="carousel__track" data-carousel-track>
          {%- for product in recommendations.products -%}{% render 'product-card', product: product %}{%- endfor -%}
        </div>
        <button class="carousel__nav carousel__nav--next" data-carousel-next aria-label="Next">{% render 'icon', name: 'chevron-right', size: 18 %}</button>
      </div>
    </div>
  </section>
{%- elsif recommendations.performed == false -%}
  <section class="section" data-related-fetch="{{ product.id }}" data-related-limit="{{ section.settings.limit }}">
    <div class="page-width">
      <div class="section-head"><div class="section-head__titles"><h2>{{ section.settings.heading | default: 'You may also like' }}</h2></div></div>
      <div class="carousel" data-carousel><div class="carousel__track" data-carousel-track data-related-target></div></div>
    </div>
  </section>
  <script>
    (function(){
      var s = document.querySelector('[data-related-fetch]');
      if(!s) return;
      var id = s.getAttribute('data-related-fetch'), limit = s.getAttribute('data-related-limit') || 6;
      fetch('{{ routes.product_recommendations_url }}?section_id=related-products&product_id='+id+'&limit='+limit)
        .then(function(r){return r.text();})
        .then(function(html){
          var d=document.createElement('div'); d.innerHTML=html;
          var fresh=d.querySelector('[data-carousel-track]');
          if(fresh && fresh.children.length){ s.parentNode.replaceChild(d.querySelector('.section')||d.firstElementChild, s); }
          else { s.style.display='none'; }
        }).catch(function(){ s.style.display='none'; });
    })();
  </script>
{%- endif -%}
{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "range", "id": "limit", "label": "Products", "min": 4, "max": 10, "step": 1, "default": 6 }
  ],
  "presets": [ { "name": "Related products" } ]
}
{% endschema %}
