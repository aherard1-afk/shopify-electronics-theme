{%- comment -%} Thin top utility bar: promo message + utility links + currency/country. {%- endcomment -%}
<div class="utility-bar">
  <div class="page-width utility-bar__inner">
    <p class="utility-bar__msg">{% render 'icon', name: 'truck', size: 15 %} {{ section.settings.message }}</p>
    {%- if section.settings.show_links -%}
      <div class="utility-bar__links">
        {%- if section.settings.help_page != blank -%}<a href="{{ section.settings.help_page }}">Help</a>{%- else -%}<a href="/pages/faqs">Help</a>{%- endif -%}
        <a href="{{ routes.account_url }}">Track order</a>
        <a href="{{ routes.account_url }}">Account</a>
        {%- if shop.enabled_currencies.size > 1 or localization.available_countries.size > 1 -%}
          {%- form 'localization', class: 'utility-bar__loc' -%}
            <select name="country_code" onchange="this.form.submit()" aria-label="Country / currency" style="min-height:auto;height:28px;padding:2px 8px;font-size:.8rem;background:transparent;border-color:var(--gunmetal-600);color:var(--gunmetal-300)">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>{{ country.name }} ({{ country.currency.iso_code }})</option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "message", "label": "Promo / trust message", "default": "Fast shipping on select electronics — expert support available." },
    { "type": "checkbox", "id": "show_links", "label": "Show utility links", "default": true },
    { "type": "url", "id": "help_page", "label": "Help link" }
  ]
}
{% endschema %}
