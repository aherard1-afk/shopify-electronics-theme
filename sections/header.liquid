{%- comment -%} Main header: logo, category-aware search, account, cart, support CTA, theme toggle, nav. {%- endcomment -%}
<header class="site-header" data-sticky-header>
  <div class="page-width">
    <div class="header__inner">
      <button type="button" class="header-icon header__burger" data-open-layer="mobile-menu" aria-label="{{ 'general.accessibility.open_menu' | t }}">
        {% render 'icon', name: 'menu', size: 24 %}
      </button>

      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 240 }}" alt="{{ shop.name | escape }}" width="120">
        {%- else -%}
          <span class="logo-mark">●</span>{{ settings.logo_text | default: shop.name }}
        {%- endif -%}
      </a>

      <form action="{{ routes.search_url }}" method="get" class="header__search search-form" role="search">
        <input type="hidden" name="type" value="product">
        {%- if section.settings.category_search and linklists.main-menu.links.size > 0 -%}
          <select class="search-form__cat" name="q_type" aria-label="Category" disabled title="Category-aware search">
            <option>All categories</option>
            {%- for link in linklists.main-menu.links limit: 6 -%}<option>{{ link.title }}</option>{%- endfor -%}
          </select>
        {%- endif -%}
        <input class="input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.label' | t }}">
        <button type="submit" class="search-form__submit" aria-label="{{ 'general.search.submit' | t }}">{% render 'icon', name: 'search', size: 18 %}</button>
      </form>

      <div class="header__actions">
        <button type="button" class="header-icon theme-toggle" data-theme-toggle aria-label="Toggle dark mode" aria-pressed="false">
          <span class="icon-moon">{% render 'icon', name: 'moon', size: 20 %}</span>
          <span class="icon-sun">{% render 'icon', name: 'sun', size: 20 %}</span>
        </button>
        <a href="{{ section.settings.support_link | default: '/pages/contact' }}" class="header-icon header-icon--cta" style="display:none">{% render 'icon', name: 'headset', size: 18 %} <span>Get help</span></a>
        <a href="{{ routes.account_url }}" class="header-icon" aria-label="Account">{% render 'icon', name: 'user', size: 22 %}</a>
        <a href="{% if settings.cart_type == 'page' %}{{ routes.cart_url }}{% else %}#cart-drawer{% endif %}" class="header-icon" {% if settings.cart_type == 'drawer' %}data-open-layer="cart-drawer"{% endif %} aria-label="{{ 'general.accessibility.open_cart' | t }}">
          {% render 'icon', name: 'cart', size: 22 %}
          <span class="cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>

  <nav class="main-nav" aria-label="Primary">
    <div class="page-width">
      <ul class="main-nav__list">
        {%- for link in linklists.main-menu.links -%}
          <li class="main-nav__item">
            <a href="{{ link.url }}" class="main-nav__link" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}{% if link.links.size > 0 %} {% render 'icon', name: 'chevron-down', size: 14 %}{% endif %}</a>
            {%- if link.links.size > 0 -%}
              <div class="mega">
                {%- for child in link.links -%}<a href="{{ child.url }}">{{ child.title }}</a>{%- endfor -%}
              </div>
            {%- endif -%}
          </li>
        {%- else -%}
          {%- comment -%} Fallback nav when no menu is configured yet {%- endcomment -%}
          <li class="main-nav__item"><a href="{{ routes.root_url }}" class="main-nav__link">Home</a></li>
          <li class="main-nav__item"><a href="{{ routes.all_products_collection_url }}" class="main-nav__link">Shop</a></li>
          <li class="main-nav__item"><a href="{{ routes.root_url }}#best-sellers" class="main-nav__link">Best Sellers</a></li>
          <li class="main-nav__item"><a href="{{ routes.collections_url }}?sort_by=created-descending" class="main-nav__link">New Arrivals</a></li>
          <li class="main-nav__item"><a href="{{ routes.collections_url }}" class="main-nav__link">Categories</a></li>
          <li class="main-nav__item"><a href="/pages/services" class="main-nav__link">Services</a></li>
          <li class="main-nav__item"><a href="/pages/faqs" class="main-nav__link">FAQs</a></li>
          <li class="main-nav__item"><a href="/pages/contact" class="main-nav__link">Contact</a></li>
        {%- endfor -%}
      </ul>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "checkbox", "id": "category_search", "label": "Category-aware search dropdown", "default": true },
    { "type": "url", "id": "support_link", "label": "Support CTA link" }
  ]
}
{% endschema %}
