{%- comment -%} Reusable rich-text block for content/policy pages. Copy lives in settings. {%- endcomment -%}
<section class="section{% if section.settings.tight %} section--tight{% endif %}">
  <div class="page-width" style="max-width:{{ section.settings.width | default: 820 }}px">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 style="margin-bottom:16px">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="rte">{{ section.settings.content }}</div>
    {%- if section.settings.cta_label != blank -%}<div style="margin-top:24px"><a href="{{ section.settings.cta_link }}" class="btn btn--accent">{{ section.settings.cta_label }}</a></div>{%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add your content here.</p>" },
    { "type": "range", "id": "width", "label": "Max width (px)", "min": 600, "max": 1100, "step": 20, "default": 820 },
    { "type": "checkbox", "id": "tight", "label": "Tighter spacing", "default": false },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [ { "name": "Rich text" } ]
}
{% endschema %}
