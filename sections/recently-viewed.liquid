{%- comment -%} Recently viewed — populated client-side from localStorage by global.js. {%- endcomment -%}
<section class="section" data-recent-section>
  <div class="page-width">
    <div class="section-head"><div class="section-head__titles"><h2>{{ section.settings.heading | default: 'Recently viewed' }}</h2></div></div>
    <div class="carousel" data-carousel data-recently-viewed>
      <button class="carousel__nav carousel__nav--prev" data-carousel-prev aria-label="Previous">{% render 'icon', name: 'chevron-left', size: 18 %}</button>
      <div class="carousel__track" data-carousel-track></div>
      <button class="carousel__nav carousel__nav--next" data-carousel-next aria-label="Next">{% render 'icon', name: 'chevron-right', size: 18 %}</button>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Recently viewed",
  "settings": [ { "type": "text", "id": "heading", "label": "Heading", "default": "Recently viewed" } ],
  "presets": [ { "name": "Recently viewed" } ]
}
{% endschema %}
