{%- comment -%} "Our range" — category tiles. Pulls image from chosen collection if no custom image. {%- endcomment -%}
<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div class="section-head__titles">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading | default: 'Shop our range' }}</h2>
      </div>
      <a href="{{ routes.collections_url }}" class="link-arrow">All categories {% render 'icon', name: 'arrow-right', size: 16 %}</a>
    </div>
    <div class="cat-grid">
      {%- for block in section.blocks -%}
        {%- assign c = collections[block.settings.collection] -%}
        {%- assign url = block.settings.link | default: c.url | default: routes.collections_url -%}
        <a class="cat-tile {% unless block.settings.image or c.image or c.products.first.featured_media %}cat-tile--empty{% endunless %}" href="{{ url }}" {{ block.shopify_attributes }}>
          <div class="cat-tile__img">
            {%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- elsif c.image != blank -%}{{ c.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: c.title }}
            {%- elsif c.products.first.featured_media != blank -%}{{ c.products.first.featured_media | image_url: width: 500 | image_tag: loading: 'lazy', alt: c.title }}
            {%- endif -%}
          </div>
          <span class="cat-tile__label"><small>{{ block.settings.kicker | default: 'Category' }}</small>{{ block.settings.title | default: c.title | default: 'Category' }}</span>
        </a>
      {%- else -%}
        {%- assign defaults = 'Audio,Phones,Laptops,Smart Home,Smart Watches,Monitors,Accessories,Gaming' | split: ',' -%}
        {%- for d in defaults -%}
          <a class="cat-tile cat-tile--empty" href="{{ routes.collections_url }}"><span class="cat-tile__label"><small>Category</small>{{ d }}</span></a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our range" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop our range" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" },
        { "type": "text", "id": "title", "label": "Label (optional override)" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link (optional override)" }
      ]
    }
  ],
  "presets": [ { "name": "Category grid", "blocks": [ { "type": "category" }, { "type": "category" }, { "type": "category" }, { "type": "category" } ] } ]
}
{% endschema %}
