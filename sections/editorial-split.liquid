{%- comment -%} Warm editorial split: image + text/CTA. "Tech that fits the way you live." {%- endcomment -%}
<section class="section">
  <div class="page-width">
    <div class="split {% if section.settings.reverse %}split--reverse{% endif %}">
      <div class="split__media reveal">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width:820px) 50vw, 100vw', widths: '500,700,900' }}
        {%- else -%}
          <div style="aspect-ratio:4/3;border-radius:var(--radius-lg);background:linear-gradient(120deg,var(--surface-2),var(--surface-3));display:grid;place-items:center" class="text-muted">{% render 'icon', name: 'home', size: 40 %}</div>
        {%- endif -%}
      </div>
      <div class="split__body reveal">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading | default: 'Tech that fits the way you live.' }}</h2>
        <p class="text-muted" style="margin:14px 0 24px;font-size:var(--fs-lg)">{{ section.settings.text | default: 'From the home office to the living room, we help you choose dependable electronics that simply work — backed by people who actually know them.' }}</p>
        {%- if section.settings.cta_label != blank -%}<a href="{{ section.settings.cta_link }}" class="btn btn--accent">{{ section.settings.cta_label }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Everyday tech" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tech that fits the way you live." },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop smart home" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [ { "name": "Editorial split" } ]
}
{% endschema %}
