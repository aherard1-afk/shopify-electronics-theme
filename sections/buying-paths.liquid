{%- comment -%} 2–3 large buying-path cards: Work from home, Everyday essentials, Gaming, Smart home. {%- endcomment -%}
<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div class="section-head__titles">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading | default: 'Find your setup' }}</h2>
      </div>
    </div>
    <div class="paths">
      {%- for block in section.blocks -%}
        {%- assign c = collections[block.settings.collection] -%}
        <a class="path-card reveal" href="{{ block.settings.link | default: c.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          <div class="path-card__img">
            {%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- elsif c.image != blank -%}{{ c.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}<div style="position:absolute;inset:0;background:linear-gradient(120deg,var(--gunmetal-700),var(--gunmetal-500))"></div>{%- endif -%}
          </div>
          <div class="path-card__body">
            <h3>{{ block.settings.title | default: 'Work from home' }}</h3>
            <p style="opacity:.9;font-size:.9rem;margin-bottom:10px">{{ block.settings.text | default: 'Everything you need for a focused, comfortable setup.' }}</p>
            <span class="link-arrow" style="color:#fff">{{ block.settings.cta | default: 'Explore' }} {% render 'icon', name: 'arrow-right', size: 16 %}</span>
          </div>
        </a>
      {%- else -%}
        {%- assign titles = 'Work from home,Everyday essentials,Gaming &amp; entertainment' | split: ',' -%}
        {%- for t in titles -%}
          <a class="path-card" href="{{ routes.all_products_collection_url }}">
            <div class="path-card__img"><div style="position:absolute;inset:0;background:linear-gradient(120deg,var(--gunmetal-700),var(--gunmetal-500))"></div></div>
            <div class="path-card__body"><h3>{{ t }}</h3><span class="link-arrow" style="color:#fff">Explore {% render 'icon', name: 'arrow-right', size: 16 %}</span></div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Buying paths",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by need" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your setup" }
  ],
  "blocks": [
    {
      "type": "path",
      "name": "Path card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "Work from home" },
        { "type": "text", "id": "text", "label": "Text", "default": "Everything you need for a focused, comfortable setup." },
        { "type": "text", "id": "cta", "label": "CTA label", "default": "Explore" },
        { "type": "url", "id": "link", "label": "Link (optional override)" }
      ]
    }
  ],
  "presets": [ { "name": "Buying paths", "blocks": [ { "type": "path" }, { "type": "path" }, { "type": "path" } ] } ]
}
{% endschema %}
