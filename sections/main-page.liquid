{%- comment -%} Default page template: renders the Shopify page title + body. {%- endcomment -%}
<section class="section">
  <div class="page-width" style="max-width:820px">
    <h1 style="margin-bottom:20px">{{ page.title }}</h1>
    <div class="rte">{{ page.content }}</div>
  </div>
</section>
{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
