{%- comment -%} Search results: clean, helpful, never blank/broken. {%- endcomment -%}
{%- paginate search.results by 24 -%}
<section class="section">
  <div class="page-width">
    <form action="{{ routes.search_url }}" method="get" class="search-form" role="search" style="max-width:620px;margin-bottom:24px">
      <input type="hidden" name="type" value="product">
      <input class="input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.label' | t }}">
      <button type="submit" class="search-form__submit" aria-label="{{ 'general.search.submit' | t }}">{% render 'icon', name: 'search', size: 18 %}</button>
    </form>

    {%- if search.performed -%}
      <h1 style="font-size:var(--fs-h3);margin-bottom:6px">{{ 'general.search.results_for' | t }} “{{ search.terms }}”</h1>
      <p class="collection-count" style="margin-bottom:22px">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</p>

      {%- if search.results.size > 0 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}{% render 'product-card', product: item %}
            {%- else -%}
              <a class="card reveal" href="{{ item.url }}" style="padding:18px;display:block"><span class="product-card__vendor">{{ item.object_type }}</span><h3 class="product-card__title">{{ item.title }}</h3>{%- if item.content -%}<p class="text-muted" style="font-size:.85rem;margin-top:6px">{{ item.content | strip_html | truncatewords: 22 }}</p>{%- endif -%}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav style="display:flex;gap:8px;justify-content:center;margin-top:40px;flex-wrap:wrap" aria-label="Pagination">
            {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="btn btn--outline btn--sm">Prev</a>{%- endif -%}
            {%- for part in paginate.parts -%}{%- if part.is_link -%}<a href="{{ part.url }}" class="btn btn--outline btn--sm">{{ part.title }}</a>{%- else -%}<span class="btn btn--sm" style="background:var(--accent);border-color:var(--accent);color:#fff">{{ part.title }}</span>{%- endif -%}{%- endfor -%}
            {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="btn btn--outline btn--sm">Next</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="empty-state">
          {% render 'icon', name: 'search', size: 40 %}
          <h2 style="margin:14px 0 8px">{{ 'general.search.no_results' | t }}</h2>
          <p class="text-muted">We couldn't find a match. Check the spelling or browse a category below.</p>
          <div class="empty-state__cats">
            <a href="{{ routes.collections_url }}" class="btn btn--outline btn--sm">All categories</a>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--sm">All products</a>
            <a href="/pages/contact" class="btn btn--outline btn--sm">Contact support</a>
          </div>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="empty-state">{% render 'icon', name: 'search', size: 40 %}<h2 style="margin:14px 0 8px">Search our store</h2><p class="text-muted">Find phones, laptops, audio, smart home, and more.</p></div>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
