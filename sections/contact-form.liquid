{%- comment -%} Contact: form + support details. Uses Shopify's built-in contact form. {%- endcomment -%}
<section class="section">
  <div class="page-width">
    <div class="split">
      <div class="split__body" style="max-width:none">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'Contact' }}</span>
        <h1 style="margin-bottom:10px">{{ section.settings.heading | default: 'Get in touch' }}</h1>
        <p class="text-muted" style="margin-bottom:24px">{{ section.settings.intro | default: "Questions about a product, an order, or compatibility? Our team is here to help." }}</p>

        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p class="verified" style="margin-bottom:16px">{% render 'icon', name: 'check', size: 14 %} Thanks — we received your message and will reply soon.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p style="color:var(--danger);margin-bottom:16px">Please check the highlighted fields and try again.</p>
          {%- endif -%}
          <div class="grid" style="grid-template-columns:1fr 1fr;gap:14px">
            <div class="field"><label for="cf-name">Name</label><input class="input" id="cf-name" type="text" name="contact[name]" required></div>
            <div class="field"><label for="cf-email">Email</label><input class="input" id="cf-email" type="email" name="contact[email]" required></div>
          </div>
          <div class="field" style="margin-top:14px"><label for="cf-subject">Subject</label><input class="input" id="cf-subject" type="text" name="contact[subject]"></div>
          <div class="field" style="margin-top:14px"><label for="cf-body">Message</label><textarea id="cf-body" name="contact[body]" required></textarea></div>
          <button type="submit" class="btn btn--accent btn--lg" style="margin-top:16px">Send message</button>
        {%- endform -%}
      </div>

      <div class="split__media" style="order:0">
        <div class="card" style="padding:28px">
          <h3 style="margin-bottom:16px">Support details</h3>
          <p style="display:flex;align-items:center;gap:10px;margin-bottom:12px">{% render 'icon', name: 'mail', size: 18 %} <a href="mailto:{{ settings.support_email }}" style="color:var(--accent)">{{ settings.support_email }}</a></p>
          {%- if settings.support_phone != blank -%}<p style="display:flex;align-items:center;gap:10px;margin-bottom:12px">{% render 'icon', name: 'phone', size: 18 %} {{ settings.support_phone }}</p>{%- endif -%}
          <p style="display:flex;align-items:center;gap:10px;margin-bottom:12px">{% render 'icon', name: 'headset', size: 18 %} {{ settings.support_hours }}</p>
          {%- if section.settings.address != blank -%}<p style="display:flex;align-items:flex-start;gap:10px">{% render 'icon', name: 'home', size: 18 %} <span>{{ section.settings.address | newline_to_br }}</span></p>{%- endif -%}
          <hr>
          <p class="text-muted" style="font-size:.875rem">Looking for order help? <a href="{{ routes.account_url }}" style="color:var(--accent)">Track your order</a> or visit our <a href="/pages/faqs" style="color:var(--accent)">FAQs</a>.</p>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "textarea", "id": "address", "label": "Business address", "default": "" }
  ],
  "presets": [ { "name": "Contact form" } ]
}
{% endschema %}
